cc_binary(
    name = "PoissonRecon",
    srcs = [
        "Src/Allocator.h",
        "Src/Array.h",
        "Src/BSplineData.h",
        "Src/BSplineData.inl",
        "Src/BinaryNode.h",
        "Src/BlockedVector.h",
        "Src/CmdLineParser.h",
        "Src/CmdLineParser.inl",
        "Src/CoredMesh.h",
        "Src/CoredMesh.inl",
        "Src/FEMTree.Evaluation.inl",
        "Src/FEMTree.Initialize.inl",
        "Src/FEMTree.IsoSurface.specialized.inl",
        "Src/FEMTree.SortedTreeNodes.inl",
        "Src/FEMTree.System.inl",
        "Src/FEMTree.WeightedSamples.inl",
        "Src/FEMTree.h",
        "Src/FEMTree.inl",
        "Src/Factor.h",
        "Src/Geometry.h",
        "Src/Geometry.inl",
        "Src/Image.h",
        "Src/JPEG.h",
        "Src/JPEG.inl",
        "Src/MAT.h",
        "Src/MAT.inl",
        "Src/MarchingCubes.h",
        "Src/MyMiscellany.h",
        "Src/PNG.h",
        "Src/PNG.inl",
        "Src/PPolynomial.h",
        "Src/PPolynomial.inl",
        "Src/Ply.h",
        "Src/Ply.inl",
        "Src/PlyFile.h",
        "Src/PlyFile.inl",
        "Src/PoissonRecon.cpp",
        "Src/Polynomial.h",
        "Src/Polynomial.inl",
        "Src/PreProcessor.h",
        "Src/Rasterizer.h",
        "Src/Rasterizer.inl",
        "Src/RegularGrid.h",
        "Src/RegularGrid.inl",
        "Src/RegularTree.h",
        "Src/RegularTree.inl",
        "Src/SparseMatrix.h",
        "Src/SparseMatrix.inl",
        "Src/SparseMatrixInterface.h",
        "Src/SparseMatrixInterface.inl",
        "Src/VertexFactory.h",
        "Src/VertexFactory.inl",
        "Src/VertexStream.h",
        "Src/VertexStream.inl",
        "Src/Window.h",
        "Src/Window.inl",
    ],
    copts = [
        "-std=c++14",
        "-Wno-error",
        "-w",
        "-fopenmp",
        "--param ggc-min-expand=10",
        "--param ggc-min-heapsize=8192"
