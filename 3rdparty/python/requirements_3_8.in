-r requirements_ncore.in

# To run tests
pytest
parameterized

# Public API dependencies (mimic restrictive dependencies using old numpy)
numpy<1.20 # in particular, older versions don't ship numpy.typing type hints
zarr<=2.13.3 # more recent versions require numpy>=1.20

--find-links https://download.pytorch.org/whl/torch_stable.html
torch==1.12.1+cu116

# secondary dependencies used in tests / scripts
opencv-python-headless
debugpy
click
