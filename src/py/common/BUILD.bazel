load("@cgrindel_bazel_starlib//bzlformat:defs.bzl", "bzlformat_pkg")
load("@pip_deps//:requirements.bzl", "requirement")
load("@rules_python//python:defs.bzl", "py_library")
load("//bazel/pytest:defs.bzl", "pytest_test")

package(default_visibility = ["//visibility:public"])

py_library(
    name = "pylib",
    srcs = [
        "common.py",
        "nvidia_utils.py",
        "transformations.py",
        "visualization.py",
    ],
    deps = [
        requirement("numpy"),
        requirement("pillow"),
        requirement("pyarrow"),
        requirement("pandas"),  # for pyarrow::to_pandas()
        requirement("scipy"),
        requirement("tqdm"),
        requirement("matplotlib"),
        requirement("open3d"),
        requirement("multimethod"),
        "//src/cpp/av_utils:pylib",
        "//src/protos/deepmap:py_proto",
        "//src/py/data_converter:pylib_data",
    ],
)

pytest_test(
    name = "test",
    srcs = glob(["*test.py"]),
    deps = [
        ":pylib",
        "//src/cpp/av_utils:pylib",
    ],
)

bzlformat_pkg(name = "bzlformat")
