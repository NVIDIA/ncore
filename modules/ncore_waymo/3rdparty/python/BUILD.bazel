load("@rules_uv//uv:pip.bzl", "pip_compile")

PIP_COMPILE_ARGS = [
    "--generate-hashes",
    "--emit-index-url",
    "--index-strategy",
    "unsafe-best-match",
]

pip_compile(
    name = "requirements_3_11",
    size = "medium",
    args = PIP_COMPILE_ARGS + [
        "-c",
        "../ncore+/3rdparty/python/requirements_3_11.txt",
    ],
    data = ["@ncore//3rdparty/python:requirements_3_11.txt"],
    py3_runtime = "@python_3_11//:py3_runtime",
    requirements_in = "requirements.in",
    requirements_txt = "requirements_3_11.txt",
)
